{
  "enabled": true,
  "version": "1.0.0",
  "description": "PromptAtelier 内容安全审查配置",
  "layers": {
    "keyword": {
      "enabled": true,
      "description": "Layer 1: 关键词预过滤（正则表达式）",
      "action": "block"
    },
    "ai_classify": {
      "enabled": true,
      "description": "Layer 2: AI 毒性分类（Tiny-Toxic-Detector）",
      "threshold": 0.75,
      "action": "block"
    },
    "semantic": {
      "enabled": false,
      "description": "Layer 3: 语义深度审查（Qwen3-0.6B，可选）",
      "threshold": 0.8,
      "action": "warn"
    }
  },
  "blockedKeywords": [
    "自杀方法",
    "制造炸弹",
    "制造武器",
    "制造毒品",
    "how to make a bomb",
    "how to make drugs",
    "how to kill",
    "child exploitation",
    "child abuse"
  ],
  "blockedPatterns": [
    "\\b(suicide|self.?harm)\\s+(method|guide|how.?to)\\b",
    "\\b(make|build|create)\\s+(bomb|explosive|weapon)\\b",
    "\\b(drug|narcotic)\\s+(recipe|synthesis|manufacture)\\b"
  ],
  "designSafeTerms": [
    "nude tone",
    "nude color",
    "裸色",
    "肤色",
    "flesh color",
    "flesh tone",
    "skin tone",
    "body language",
